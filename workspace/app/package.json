{
  "name": "multi-code",
  "version": "0.1.0",
  "description": "Multi-Code — Claude Code instance manager",
  "author": "Jasen Pan",
  "main": "dist/main/index.js",
  "scripts": {
    "start": "pnpm build && electron dist/main/index.js",
    "build": "pnpm build:renderer && pnpm build:main",
    "build:renderer": "rspack build --config rspack.renderer.config.ts",
    "build:main": "tsc -p tsconfig.main.json",
    "rebuild-native": "electron-rebuild --version 35.7.5 --module-dir . --only better-sqlite3",
    "pack": "pnpm build && electron-builder --dir",
    "dist": "pnpm build && electron-builder",
    "lint": "oxlint && eslint --cache",
    "lint:fix": "oxlint --fix && eslint --fix",
    "type": "tsc --noEmit",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.multicode.app",
    "productName": "Multi-Code",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg",
      "icon": "build/icon.icns",
      "identity": null
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "extraResources": [],
    "asar": true
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@rspack/cli": "^1.3.0",
    "@rspack/core": "^1.3.0",
    "@rspack/dev-server": "^1.1.0",
    "@rspack/plugin-react-refresh": "^1.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.0.0",
    "css-loader": "^7.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-oxlint": "^0.16.0",
    "oxlint": "^0.16.0",
    "react-refresh": "^0.17.0",
    "style-loader": "^4.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^12.10.0",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
